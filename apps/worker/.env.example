MFB_WORKER_QUEUE=telemetry
MFB_DATABASE_URL=postgresql+asyncpg://myflightbook:myflightbook@127.0.0.1:5432/myflightbook
MFB_REDIS_URL=redis://127.0.0.1:6379/0
MFB_S3_ENDPOINT=http://127.0.0.1:9000
MFB_S3_BUCKET=myflightbook
MFB_S3_ACCESS_KEY=myflightbook
MFB_S3_SECRET_KEY=myflightbook
MFB_WORKER_MAX_JOBS=4
MFB_JOB_TIMEOUT_SECONDS=30
# Standard AWS-compatible aliases are also supported:
# AWS_ENDPOINT_URL=http://127.0.0.1:9000
# AWS_BUCKET_NAME=myflightbook
# AWS_ACCESS_KEY_ID=myflightbook
# AWS_SECRET_ACCESS_KEY=myflightbook
# AWS_REGION=us-east-1
