MFB_PROJECT_NAME=MyFlightbook API
MFB_API_V1_PREFIX=/api/v1
MFB_DATABASE_URL=postgresql+asyncpg://myflightbook:myflightbook@127.0.0.1:5432/myflightbook
MFB_SQL_ECHO=false
MFB_CORS_ORIGINS=["http://127.0.0.1:3000","http://localhost:3000"]
MFB_S3_ENDPOINT=http://127.0.0.1:9000
MFB_S3_BUCKET=myflightbook
MFB_S3_ACCESS_KEY=myflightbook
MFB_S3_SECRET_KEY=myflightbook
MFB_S3_PRESIGNED_UPLOAD_TTL_SECONDS=900
# Standard AWS-compatible aliases supported by the media storage service:
# AWS_ENDPOINT_URL=http://127.0.0.1:9000
# AWS_BUCKET_NAME=myflightbook
# AWS_ACCESS_KEY_ID=myflightbook
# AWS_SECRET_ACCESS_KEY=myflightbook
# AWS_REGION=us-east-1
MFB_DEFAULT_DEMO_EMAIL=demo@myflightbook.local
MFB_OIDC_GOOGLE_CLIENT_IDS=["your-google-web-client-id"]
MFB_OIDC_APPLE_CLIENT_IDS=["your-apple-services-id"]
MFB_OIDC_HTTP_TIMEOUT_SECONDS=5
MFB_OIDC_METADATA_CACHE_TTL_SECONDS=3600
MFB_OIDC_CLOCK_SKEW_SECONDS=60
MFB_LEGACY_MYSQL_HOST=
MFB_LEGACY_MYSQL_PORT=3306
MFB_LEGACY_MYSQL_DATABASE=
MFB_LEGACY_MYSQL_USERNAME=
MFB_LEGACY_MYSQL_PASSWORD=
